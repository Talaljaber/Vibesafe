{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"]
  },
  "references": [
    { "path": "../shared" },
    { "path": "../core" }
  ],
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "**/*.test.ts"]
}
